# ============================================================
# Redex Education — Environment Variable Template
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# `.env*` is gitignored except for this `.env.example` template.
#
# All Vite-exposed variables MUST start with `VITE_` — Vite only
# inlines variables with that prefix into the client bundle.
# ============================================================

# --- Supabase (public anon credentials) ----------------------
# Project URL — e.g. https://your-project-ref.supabase.co
VITE_SUPABASE_URL=

# Public anon JWT (safe to ship to clients; row-level security gates access)
VITE_SUPABASE_ANON_KEY=

# --- Data source ----------------------------------------------
# Default mock keeps local demo/dev/test flows unchanged. Set to `supabase` to read from the redex schema.
VITE_DATA_SOURCE=mock

# --- Course Foundry AI ----------------------------------------
# Default mock preserves the demo Course Foundry generation flow. Set to `real` only after Slice C deploys the generation edge functions.
VITE_AI_MODE=mock

# --- Server-side media rendering -----------------------------
# Edge Function only: keep disabled unless HeyGen credentials and a private media bucket are configured.
REDEX_ENABLE_HEYGEN_MEDIA_STAGE=false
HEYGEN_API_KEY=
REDEX_MEDIA_BUCKET=redex-media
# Optional Edge Function poll cadence override; defaults to 60 seconds.
HEYGEN_POLL_DELAY_SECONDS=60

# --- Auth scaffolding -----------------------------------------
# Keep true during mock/demo development so AuthGate does not require a real Supabase session.
VITE_MOCK_AUTH=false

# Role used by AuthGate when VITE_MOCK_AUTH=true. Defaults to admin if omitted.
VITE_MOCK_AUTH_ROLE=admin
